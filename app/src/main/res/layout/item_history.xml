<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgStatus"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#FFEBEB"
            android:padding="12dp"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:srcCompat="@drawable/ic_bolt_slash"
            app:tint="#E53935" />

        <LinearLayout
            android:id="@+id/containerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/imgStatus"
            android:layout_toStartOf="@id/btnDelete"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtStatusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coupure signalée"
                android:textColor="#E53935"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="il y a environ 4 heures"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:drawableStart="@drawable/ic_location_small"
                android:drawablePadding="6dp"
                android:text="Ouagadougou - Secteur 15"
                android:textColor="#555555"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="false"
            android:layout_alignTop="@id/imgStatus"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            app:tint="#CCCCCC" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/containerText"
            android:layout_marginTop="12dp"
            android:layout_toEndOf="@id/imgStatus"
            android:layout_marginStart="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtConfirmCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12 confirmations"
                android:textColor="#2E7D32"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtContestCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 contestations"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
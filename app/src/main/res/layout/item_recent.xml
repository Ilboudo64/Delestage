<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatar"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="#F5F5F5"
                android:padding="8dp"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:srcCompat="@drawable/ic_user" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/imgAvatar"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtNomAuteur"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Amadou K."
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_time"
                        app:tint="#888888" />

                    <TextView
                        android:id="@+id/txtTemps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="dans environ 3 heures"
                        android:textSize="11sp"
                        android:textColor="#888888" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/badgeType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_badge_red"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Coupure"
                android:textColor="#D32F2F"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                app:srcCompat="@drawable/ic_location"
                app:tint="#888888" />

            <TextView
                android:id="@+id/txtLocalisation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Ouagadougou - Secteur 15"
                android:textColor="#555555"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F0F0F0" />

        <TextView
            android:id="@+id/txtCompteurs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="12 confirment • 1 contestent"
            android:textColor="#666666"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmer"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Confirmer"
                android:textAllCaps="false"
                android:textColor="#2E7D32"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_confirm"
                app:iconTint="#2E7D32"
                app:strokeColor="#2E7D32"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContester"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Contester"
                android:textAllCaps="false"
                android:textColor="#D32F2F"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_contest"
                app:iconTint="#D32F2F"
                app:strokeColor="#D32F2F"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>